# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# For docker-compose (built-in postgres): postgresql://postgres:yourpassword@postgres:5432/postgres
# For external DB (e.g. Bitnami on NAS):  postgresql://Admin:Secret@postgres_db:5432/mydatabase
DATABASE_URL=postgresql://postgres:yourpassword@postgres:5432/postgres

# Session signing key — generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_long_random_string

# ─── Optional ─────────────────────────────────────────────────────────────────

# Google AI (for AI features)
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1

# n8n integration
N8N_API_KEY=

# ─── Docker Compose (built-in postgres only) ──────────────────────────────────
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=postgres
POSTGRES_USER=postgres
